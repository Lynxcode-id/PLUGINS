function buildCookie(deviceId, chatId) {
  return `NEXT_LOCALE=id; u_device_id=${deviceId}; home_chat_id=${chatId}`;
}

let handler = async (m, { conn, text, usedPrefix, command }) => {
    const headerUI = "┌˚₊ ๑│ ᴇ ʀ ɪ ɴ ᴇ - ᴀ ɪ  ᴋ ᴏ ʙ ᴏ │๑˚₊";
    const hrUI = "└˚₊ ๑ ────────────── ๑˚₊";
    const footerUI = "> © ERINE-AI | KOBO AI";

    const isKasar = /kontol|memek|pepek|ngentot|perek|porno|seks|bokep|bangsat|anj/i.test(text);
    if (isKasar) {
        await m.react('💢');
        return conn.sendMessage(m.chat, { text: `${headerUI} 💢\n┇ \n│ ${getMarahMessage('kasar')}\n┇ \n${hrUI}\n${footerUI}` }, { quoted: m });
    }

    if (!text) {
        await m.react('🙄');
        return conn.sendMessage(m.chat, { text: `${headerUI} 💢\n┇ \n│ ${getMarahMessage('salah')}\n┇ \n${hrUI}\n${footerUI}` }, { quoted: m });
    }

    await m.react('⏳');
    try {
        const API = "https://app.unlimitedai.chat/api/chat";
        const chatId = crypto.randomUUID();
        const deviceId = crypto.randomUUID();
        
        const koboPrompt = "Kamu Kobo Kanaeru. Bicara casual, campur Jawa/Jepang. Suka bilang DAJOOR!, HMPH!, EHE~. Panggil user Kobo-kun. Jawab: ";
        
        const response = await axios({
            method: "POST",
            url: API,
            data: {
                chatId,
                messages: [{ id: crypto.randomUUID(), role: "user", content: koboPrompt + text }],
                selectedChatModel: "chat-model-reasoning",
                deviceId,
                locale: "id",
            },
            headers: {
                "user-agent": "Mozilla/5.0 (Linux; Android 10; K) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/147.0.0.0 Mobile Safari/537.36",
                "content-type": "application/json",
                cookie: buildCookie(deviceId, chatId)
            },
            responseType: "stream"
        });

        let answer = "";
        await new Promise((resolve) => {
            response.data.on("data", (c) => {
                try {
                    const json = JSON.parse(c.toString());
                    if (json.delta) answer += json.delta;
                } catch {}
            });
            response.data.on("end", resolve);
        });

        await m.react('✅');
        await conn.sendMessage(m.chat, { text: `${headerUI} ✨\n┇ \n${answer.trim()}\n┇ \n${hrUI}\n${footerUI}` }, { quoted: m });

    } catch (e) {
        await m.react('❌');
        m.reply("AI Error: " + e.message);
    }
}

handler.command = /^(koboai|kobo)$/i;
export default handler;