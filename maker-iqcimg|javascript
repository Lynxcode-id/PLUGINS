    if (!mime.startsWith('image/')) {
        return m.reply(`в”ЊЛљв‚Љ а№‘в”‚ ЙЄ З« бґ„  бґЌ бґЂ бґ‹ бґ‡ КЂ в”‚а№‘Лљв‚Љ рџЋЁ\nв”‡ \nв”‚ вќЊ *Gambarnya mana cuy?*\nв”‚ \nв”‚ рџ“Њ *Cara pakai:*\nв”‚ Kirim/balas gambar dengan caption:\nв”‚ ${usedPrefix + command} <teks>|<baterai>|<jam>|<provider>\nв”‚ \nв”‚ рџ“ќ *Contoh:*\nв”‚ ${usedPrefix + command} ErineBot|100|00.00|TELKOMSEL\nв”‡ \nв””Лљв‚Љ а№‘ в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ а№‘Лљв‚Љ\n> В© ERINE-AI`)
    }

    let input = text ? text.split('|') : []
    let txt = input[0] || 'ERINE-AI'
    let battery = input[1] || '100'
    let time = input[2] || '00.00'
    let provider = input[3] || 'TELKOMSEL'

    await m.react('вЏі')

    try {
        let media = await q.download()
        
        let formData = new FormData()
        let blob = new Blob([media], { type: mime })
        formData.append('file', blob, 'upload_file')

        let upRes = await fetch('https://api.shinzu.web.id/api/upload/litterbox', {
