        if (!upJson.status || !upJson.result) throw new Error('Gagal mengunggah media ke uploader.')
        let uploadUrl = upJson.result.url
        
        let apiUrl = `https://api.cmnty.web.id/maker/iqc-image?image=${encodeURIComponent(uploadUrl)}&text=${encodeURIComponent(txt)}&battery=${encodeURIComponent(battery)}&time=${encodeURIComponent(time)}&provider=${encodeURIComponent(provider)}`

        await conn.sendMessage(m.chat, {
            image: { url: apiUrl },
            caption: `в”ЊЛљв‚Љ а№‘в”‚ ЙЄ З« бґ„  бґЌ бґЂ бґ‹ бґ‡ КЂ в”‚а№‘Лљв‚Љ рџЋЁ\nв”‡ \nв”‚ вњ… *Berhasil dibuat!*\nв”‡ \nв””Лљв‚Љ а№‘ в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ а№‘Лљв‚Љ\n> В© ERINE-AI`
        }, { quoted: m })

        await m.react('вњ…')

    } catch (error) {
        console.error('[IQC ERROR]', error)
        await m.react('вќЊ')
        m.reply(`в”ЊЛљв‚Љ а№‘в”‚ књ± КЏ књ± бґ› бґ‡ бґЌ  бґ‡ КЂ КЂ бґЏ КЂ в”‚а№‘Лљв‚Љ вќЊ\nв”‡ Gagal membuat IQC image.\nв”‡ \nв”‡ *Detail:*\nв”‡ ${error.message || String(error)}\nв””Лљв‚Љ а№‘ в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ а№‘Лљв‚Љ\n> В© ERINE-AI`)
    }
}

