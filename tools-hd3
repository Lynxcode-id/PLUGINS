import axios from 'axios'
import { FormData, Blob } from 'formdata-node'
import uploadImage from '../lib/uploadImage.js'

let handler = async (m, { conn, usedPrefix, command }) => {
    let q = m.quoted ? m.quoted : m
    let mime = (q.msg || q).mimetype || ''
    
    if (!/image\/(jpe?g|png)/.test(mime)) {
        return m.reply(`📸 Balas atau kirim gambar dengan caption *${usedPrefix + command}* untuk menjadikannya HD cuy!`)
    }

    await m.react('⏳')

    try {
        let imgBuffer = await q.download()
        let imageUrl = ''
        try {
            imageUrl = await uploadImage(imgBuffer)
        } catch (uploadError) {
            console.error('Lib uploadImage error, mencoba API Litterbox...', uploadError)
            
            let formData = new FormData()
            let blob = new Blob([imgBuffer], { type: mime })
            formData.append('file', blob, 'upload_file')
            let res = await axios.post('https://api.shinzu.web.id/api/upload/litterbox', formData, {
                headers: { 'Accept': 'application/json' }
            })
            
            if (res.data?.status && res.data?.result?.url) {
                imageUrl = res.data.result.url
            } else {
                throw new Error('Semua uploader gagal memproses gambar.')
            }
        }

        const imageStream = await axios.get(imageUrl, { responseType: 'arraybuffer' })
        const bufferStream = Buffer.from(imageStream.data, 'binary')
        
        const formAI = new FormData()
        const blobAI = new Blob([bufferStream], { type: 'image/jpeg' })
        formAI.append('file', blobAI, 'image.jpg')

        const resultAI = await axios.post('https://ai-services.visual-paradigm.com/api/super-resolution/file', formAI, {
            headers: {
                'origin': 'https://online.visual-paradigm.com',
                'referer': 'https://online.visual-paradigm.com/',
                'user-agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/109.0.0.0 Safari/537.36'
            },
            responseType: 'arraybuffer'
        })

        const finalBuffer = Buffer.from(resultAI.data)
        await conn.sendMessage(m.chat, { 
            image: finalBuffer, 
            caption: '✨ *Success!* Gambar lu berhasil diubah jadi HD cuy.\n\n» ᴇʀɪɴᴇ-ᴍᴅ ᴍᴀɴᴀɢᴇᴍᴇɴᴛ «' 
        }, { quoted: m })
        
        await m.react('🔥')

    } catch (e) {
        console.error(e)
        await m.react('❌')
        m.reply(`❌ *Error:* Gagal memproses gambar menjadi HD.\n\`\`\`${e.message}\`\`\``)
    }
}

handler.help = ['hd3']
handler.tags = ['ai']
handler.command = /^hd3$/i
handler.limit = true

export default handler