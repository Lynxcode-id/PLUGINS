let handler = async (m, { conn, usedPrefix, command }) => {
    let q = m.quoted ? m.quoted : m
    let mime = (q.msg || q).mimetype || ''

    if (!/image/.test(mime)) {
        return m.reply(`в”ҢЛҡвӮҠ а№‘в”Ӯ бҙң бҙҳ s бҙ„ бҙҖ Кҹ бҙҮ  Кң бҙ… в”Ӯа№‘ЛҡвӮҠ вҡ пёҸ\nв”Ү \nв”Ӯ вқҢ *Format salah!*\nв”Ӯ \nв”Ӯ рҹ“Ң *Cara pakai:*\nв”Ӯ Kirim atau reply foto dengan perintah ${usedPrefix + command}\nв”Ү \nв””ЛҡвӮҠ а№‘ в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ а№‘ЛҡвӮҠ\n> В© ERINE-AI`)
    }

    await m.react('вҸі')

    try {
        let media = await q.download()
        
        let upForm = new FormData()
        let upBlob = new Blob([media], { type: mime })
        upForm.append('file', upBlob, 'upscale_input.jpg')

        let uploadRes = await fetch('https://api.shinzu.web.id/api/upload/litterbox', {
            method: 'POST',
            body: upForm
        })
        let uploadJson = await uploadRes.json()
        if (!uploadJson.status || !uploadJson.result) throw new Error('Gagal mengunggah media ke awan penyimpanan.')

        let targetForm = new FormData()
        targetForm.append('tool', 'upscaler')
        targetForm.append('mode', 'batch')
        targetForm.append('scaleRadio', '2')
        targetForm.append('file', upBlob, { filename: 'image.jpg', contentType: mime })

        let apiRes = await fetch('https://imgupscaler.com/api/legacy/upload', {
            method: 'POST',
            headers: {
                ...COMMON_HEADERS
            },
            body: targetForm
        })

        let apiJson = await apiRes.json()
        let taskId = apiJson?.data?.code || apiJson?.taskId
        if (!taskId) throw new Error('Gagal memperoleh Token Antrean ID dari ImgUpscaler.')

        let isComplete = false
        let downloadUrl = null
        let attempts = 0
        const maxAttempts = 15

        while (!isComplete && attempts < maxAttempts) {
            attempts++
            let statusRes = await fetch('https://imgupscaler.com/api/legacy/status', {
                method: 'POST',
                headers: {
                    ...COMMON_HEADERS,
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({ tool: "upscaler", taskId: taskId, scaleRadio: "2" })
            })

            let statusJson = await statusRes.json()
            let status = statusJson?.status || statusJson?.raw?.data?.status

            if (status === 'success') {
                isComplete = true
                let urls = statusJson?.downloadUrls || statusJson?.raw?.data?.downloadUrls
                if (urls && urls.length > 0) {
                    downloadUrl = urls[0]
                }
            } else {
                await new Promise(resolve => setTimeout(resolve, 3000))
            }
        }

        if (!downloadUrl) throw new Error('Waktu tunggu habis! Antrean server target padat.')

        let finalRes = await fetch(downloadUrl, {
            headers: {
                'User-Agent': USER_AGENT,
                'Referer': 'https://imgupscaler.com/'
            }
        })
        let resultBuffer = Buffer.from(await finalRes.arrayBuffer())

        let caption = `в”ҢЛҡвӮҠ а№‘в”Ӯ бҙң бҙҳ s бҙ„ бҙҖ Кҹ бҙҮ  Кң бҙ… в”Ӯа№‘ЛҡвӮҠ вңЁ\n` +
                      `в”Ү \n` +
                      `в”Ӯ вң… *Sukses meningkatkan resolusi!*\n` +
                      `в”Ӯ рҹ‘Ө *Scraper By:* jerexd\n` +
                      `в”Ү \n` +
                      `в””ЛҡвӮҠ а№‘ в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ а№‘ЛҡвӮҠ\n` +
                      `> В© ERINE-AI`

        await conn.sendMessage(m.chat, {
            image: resultBuffer,
            caption: caption
        }, { quoted: m })

        await m.react('вң…')

    } catch (error) {
        console.error('[UPSCALE ERROR]', error)
        await m.react('вқҢ')
        
        let errMsg = error.message || String(error)
        if (errMsg.length > 500) errMsg = errMsg.substring(0, 500) + '... (cek console)'

        m.reply(`в”ҢЛҡвӮҠ а№‘в”Ӯ s КҸ s бҙӣ бҙҮ бҙҚ  бҙҮ КҖ КҖ бҙҸ КҖ в”Ӯа№‘ЛҡвӮҠ вқҢ\nв”Ү Terjadi kesalahan sistem.\nв”Ү *Detail:* ${errMsg}\nв””ЛҡвӮҠ а№‘ в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ а№‘ЛҡвӮҠ\n> В© ERINE-AI`)
    }
}

