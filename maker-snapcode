let handler = async (m, { conn, text, usedPrefix, command }) => {
    let codeText = text ? text : (m.quoted && m.quoted.text ? m.quoted.text : '')

    if (!codeText) {
        return m.reply(`в”ҢЛҡвӮҠ а№‘в”Ӯ бҙ„ бҙҸ бҙ… бҙҮ  s Йҙ бҙҖ бҙҳ в”Ӯа№‘ЛҡвӮҠ вҡ пёҸ\nв”Ү \nв”Ӯ вқҢ *Format salah!*\nв”Ӯ \nв”Ӯ рҹ“Ң *Cara pakai:*\nв”Ӯ ${usedPrefix + command} <code>\nв”Ӯ _Atau reply/balas pesan yang berisi code._\nв”Ү \nв””ЛҡвӮҠ а№‘ в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ а№‘ЛҡвӮҠ\n> В© ERINE-AI`)
    }

    await m.react('вҸі')

    try {
        const apiUrl = `https://restapi.jagoanproject.web.id/api/maker/codesnap?code=${encodeURIComponent(codeText)}`
        
        const res = await fetch(apiUrl, {
            headers: {
                'Authorization': 'Bearer Lynxdecode'
            }
        })

        const contentType = res.headers.get('content-type')
        let mediaPayload

        if (contentType && contentType.includes('application/json')) {
            const json = await res.json()
            if (!json.status || !json.data || !json.data.result || !json.data.result.url) {
                throw new Error('Gagal mendapatkan URL dari respon JSON API.')
            }
            mediaPayload = { url: json.data.result.url }
        } else {
            const buffer = Buffer.from(await res.arrayBuffer())
            mediaPayload = buffer
        }

        let caption = `в”ҢЛҡвӮҠ а№‘в”Ӯ бҙ„ бҙҸ бҙ… бҙҮ  s Йҙ бҙҖ бҙҳ в”Ӯа№‘ЛҡвӮҠ рҹ’»\n` +
                      `в”Ү \n` +
                      `в”Ӯ вң… *Sukses membuat snapshot code!*\n` +
                      `в”Ү \n` +
                      `в””ЛҡвӮҠ а№‘ в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ а№‘ЛҡвӮҠ\n` +
                      `> В© ERINE-AI`

        await conn.sendMessage(m.chat, {
            image: mediaPayload,
            caption: caption
        }, { quoted: m })

        await m.react('вң…')

    } catch (error) {
        console.error('[CODESNAP ERROR]', error)
        await m.react('вқҢ')
        m.reply(`в”ҢЛҡвӮҠ а№‘в”Ӯ s КҸ s бҙӣ бҙҮ бҙҚ  бҙҮ КҖ КҖ бҙҸ КҖ в”Ӯа№‘ЛҡвӮҠ вқҢ\nв”Ү Terjadi kesalahan sistem.\nв”Ү *Detail:* ${error.message || String(error)}\nв””ЛҡвӮҠ а№‘ в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ а№‘ЛҡвӮҠ\n> В© ERINE-AI`)
    }
}

handler.help = ['codesnap <teks/reply>']
handler.tags = ['maker']
handler.command = /^(codesnap|csnap)$/i
handler.limit = true

export default handler