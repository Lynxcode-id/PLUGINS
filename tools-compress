import fetch from 'node-fetch'
import { CookieJar } from 'tough-cookie'
import makeFetchCookie from 'fetch-cookie'

const jar = new CookieJar()
const fetchWithCookies = makeFetchCookie(fetch, jar)

async function tinyPng(buffer, mime) {
    await fetchWithCookies('https://tinypng.com/', {
        headers: {
            'user-agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36',
            'accept': 'text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8'
        }
    })

    const allowedMimes = {
        'image/png': 'image/png',
        'image/jpeg': 'image/jpeg',
        'image/webp': 'image/webp',
        'image/avif': 'image/avif'
    }

    const originalType = allowedMimes[mime] || 'image/png'

    const upload = await fetchWithCookies('https://tinypng.com/backend/opt/store', {
        method: 'POST',
        headers: {
            'accept': 'application/json, text/plain, */*',
            'content-type': 'application/octet-stream',
            'origin': 'https://tinypng.com',
            'referer': 'https://tinypng.com/',
            'user-agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36'
        },
        body: buffer
    })

    if (!upload.ok) throw new Error(await upload.text())

    const uploaded = await upload.json()

    const processRes = await fetchWithCookies('https://tinypng.com/backend/opt/process', {
        method: 'POST',
        headers: {
            'accept': 'application/json, text/plain, */*',
            'content-type': 'application/json',
            'origin': 'https://tinypng.com',
            'referer': 'https://tinypng.com/',
            'user-agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36'
        },
        body: JSON.stringify({
            key: uploaded.key,
            originalType: originalType,
            originalSize: buffer.length
        })
    })

    if (!processRes.ok) throw new Error(await processRes.text())

    const result = await processRes.json()
    const resultUrl = result.url || result.output?.url

    const outRes = await fetchWithCookies(resultUrl, {
        headers: {
            'user-agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36',
            'referer': 'https://tinypng.com/'
        }
    })
    const outBuffer = await outRes.buffer()

    const inSize = buffer.length
    const outSize = outBuffer.length
    const ratio = (100 - ((outSize / inSize) * 100)).toFixed(2)

    return {
        status: true,
        result_url: resultUrl,
        buffer: outBuffer,
        input_size: inSize,
        output_size: outSize,
        ratio: ratio
    }
}

function formatSize(bytes) {
    if (!bytes || isNaN(bytes)) return '0 B'
    const k = 1024
    const sizes = ['B', 'KB', 'MB', 'GB', 'TB']
    const i = Math.floor(Math.log(bytes) / Math.log(k))
    return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i]
}

