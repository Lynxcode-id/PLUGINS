    }

    await m.react('вҸі')

    try {
        let media = await q.download()
        
        let res = await tinyPng(media, mime)

        if (!res.status || !res.buffer) {
            throw new Error('Gagal mengkompres gambar dari server TinyPNG.')
        }

        let caption = `в”ҢЛҡвӮҠ а№‘в”Ӯ бҙӣ ЙӘ Йҙ КҸ бҙҳ Йҙ Йў в”Ӯа№‘ЛҡвӮҠ рҹ–јпёҸ\nв”Ү \n`
        caption += `в”Ӯ вң… *Berhasil kompres foto!*\n`
        caption += `в”Ӯ рҹ“ү *Ukuran Awal:* ${formatSize(res.input_size)}\n`
        caption += `в”Ӯ рҹ“ү *Ukuran Akhir:* ${formatSize(res.output_size)}\n`
        caption += `в”Ӯ рҹ“Ҡ *Hemat:* ${res.ratio}%\n`
        caption += `в”Ү \nв””ЛҡвӮҠ а№‘ в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ а№‘ЛҡвӮҠ\n> В© ERINE-AI`

        await conn.sendMessage(m.chat, { 
            image: res.buffer, 
            caption: caption 
        }, { quoted: m })

        await m.react('вң…')
    } catch (error) {
        console.error('[TINYPNG ERROR]', error)
        await m.react('вқҢ')
        m.reply(`в”ҢЛҡвӮҠ а№‘в”Ӯ кңұ КҸ кңұ бҙӣ бҙҮ бҙҚ  бҙҮ КҖ КҖ бҙҸ КҖ в”Ӯа№‘ЛҡвӮҠ вқҢ\nв”Ү Gagal memproses gambar.\nв”Ү \nв”Ү *Detail:*\nв”Ү ${error.message || String(error)}\nв””ЛҡвӮҠ а№‘ в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ а№‘ЛҡвӮҠ\n> В© ERINE-AI`)
    }
}

