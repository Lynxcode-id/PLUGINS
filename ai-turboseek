import fetch from 'node-fetch'

let handler = async (m, { conn, text, usedPrefix, command }) => {
    if (!text) {
        return m.reply(`в”ҢЛҡвӮҠ а№‘в”Ӯ бҙӣ бҙң КҖ Кҷ бҙҸ кңұ бҙҮ бҙҮ бҙӢ в”Ӯа№‘ЛҡвӮҠ рҹҢҗ\nв”Ү \nв”Ӯ вқҢ *Mau cari berita atau informasi apa cuy?*\nв”Ӯ \nв”Ӯ рҹ“Ң *Contoh:*\nв”Ӯ ${usedPrefix + command} latest news in indonesia\nв”Ү \nв””ЛҡвӮҠ а№‘ в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ а№‘ЛҡвӮҠ\n> В© ERINE-AI`)
    }

    await m.react('вҸі')

    try {
        const apiUrl = `https://api.lexcode.biz.id/api/ai/turboseek?text=${encodeURIComponent(text)}`
        const response = await fetch(apiUrl)
        
        if (!response.ok) throw new Error(`HTTP Error: ${response.status}`)
        
        const data = await response.json()
        
        if (!data.success) throw new Error('API LexCode merespon dengan status false')

        const { answer, references } = data.result

        let caption = `в”ҢЛҡвӮҠ а№‘в”Ӯ бҙӣ бҙң КҖ Кҷ бҙҸ кңұ бҙҮ бҙҮ бҙӢ в”Ӯа№‘ЛҡвӮҠ рҹҢҗ\nв”Ү \n`
        caption += `в”Ӯ рҹ”Қ вҖә *Query:* ${text}\n`
        caption += `в”Ү \n`

        // Nampilin jawaban AI kalau ada isinya
        if (answer && answer.trim() !== '') {
            caption += `в”Ӯ рҹ“қ *AI Answer:*\nв”Ӯ ${answer.replace(/\n/g, '\nв”Ӯ ')}\nв”Ү \n`
        }

        // Nampilin referensi/sumber link
        if (references && Array.isArray(references) && references.length > 0) {
            caption += `в”Ӯ рҹ“ҡ *References:*\n`
            references.forEach((ref, index) => {
                caption += `в”Ӯ *${index + 1}.* ${ref.title}\nв”Ӯ рҹ”— ${ref.url}\nв”Ӯ \n`
            })
        } else if (!answer || answer.trim() === '') {
            // Kalau answer kosong & references kosong
            caption += `в”Ӯ _Tidak ada hasil atau referensi yang ditemukan._\nв”Ү \n`
        }

        caption += `в””ЛҡвӮҠ а№‘ в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ а№‘ЛҡвӮҠ\n> В© ERINE-AI`

        // Kirim murni teks tanpa adReply
        await conn.sendMessage(m.chat, {
            text: caption.trim()
        }, { quoted: m })

        await m.react('вң…')
    } catch (error) {
        console.error('[TURBOSEEK ERROR]', error)
        await m.react('вқҢ')
        m.reply(`в”ҢЛҡвӮҠ а№‘в”Ӯ кңұ КҸ кңұ бҙӣ бҙҮ бҙҚ  бҙҮ КҖ КҖ бҙҸ КҖ в”Ӯа№‘ЛҡвӮҠ вқҢ\nв”Ү Gagal mencari data.\nв”Ү \nв”Ү *Detail:*\nв”Ү ${error.message || String(error)}\nв””ЛҡвӮҠ а№‘ в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ а№‘ЛҡвӮҠ\n> В© ERINE-AI`)
    }
}

handler.help = ['turboseek <query>', 'news <query>']
handler.tags = ['ai', 'internet']
handler.command = /^(turboseek|ts)$/i
handler.limit = true

export default handler