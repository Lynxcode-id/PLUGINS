import axios from 'axios'

let handler = async (m, { conn, text, usedPrefix, command }) => {
    if (!text) return m.reply(`вқҢ Masukkan judul lagu yang ingin dicari cuy!\n\nContoh:\n*${usedPrefix + command} Everything u are*`)

    await m.react('вҸі')

    try {
        let apiUrl = `https://api.cuki.biz.id/api/search/soundcloud?apikey=cuki-x&query=${encodeURIComponent(text)}`
        let response = await axios.get(apiUrl)
        let resData = response.data

        if (!resData.status || !resData.data || !resData.data.results || resData.data.results.length === 0) {
            throw new Error('Lagu tidak ditemukan atau API sedang down.')
        }

        let data = resData.data.results[0]
        
        let totalSeconds = Math.floor(data.duration / 1000)
        let minutes = Math.floor(totalSeconds / 60)
        let seconds = totalSeconds % 60
        let durationText = `${minutes} menit ${seconds} detik`

        let txt = `в”ҢЛҡвӮҠ а№‘в”Ӯ s бҙҸ бҙң Йҙ бҙ… бҙ„ Кҹ бҙҸ бҙң бҙ… в”Ӯа№‘ЛҡвӮҠ рҹҺө\n` +
                  `в”Ү \n` +
                  `в”Ӯ рҹ“Ң *Judul:* ${data.permalink ? data.permalink.replace(/-/g, ' ') : '-'}\n` +
                  `в”Ӯ рҹҺ§ *Genre:* ${data.genre || '-'}\n` +
                  `в”Ӯ вҸұпёҸ *Durasi:* ${durationText}\n` +
                  `в”Ӯ рҹ‘ҒпёҸ *Diputar:* ${data.playback_count ? data.playback_count.toLocaleString() : '0'} kali\n` +
                  `в”Ӯ рҹ”— *Link:* ${data.permalink_url || '-'}\n` +
                  `в”Ү \n` +
                  `в””ЛҡвӮҠ а№‘ в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ а№‘ЛҡвӮҠ\n` +
                  `> В© ERINE-AI`

        let coverUrl = data.artwork_url || 'https://files.catbox.moe/nwvkbt.png'

        await conn.sendMessage(m.chat, { 
            image: { url: coverUrl }, 
            caption: txt 
        }, { quoted: m })

        await m.react('рҹ”Ҙ')

    } catch (e) {
        console.error(e)
        await m.react('вқҢ')
        m.reply(`в”ҢЛҡвӮҠ а№‘в”Ӯ s КҸ s бҙӣ бҙҮ бҙҚ   бҙҮ КҖ КҖ бҙҸ КҖ в”Ӯа№‘ЛҡвӮҠ вқҢ\nв”Ү Gagal mencari lagu.\nв”Ӯ *Detail:* ${e.message}\nв””ЛҡвӮҠ а№‘ в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ а№‘ЛҡвӮҠ\n> В© ERINE-AI`)
    }
}

handler.help = ['soundcloud <judul>']
handler.tags = ['search']
handler.command = /^(soundcloud|scsearch)$/i
handler.limit = true

export default handler