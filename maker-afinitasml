    if (!/image/.test(mime)) {
        return m.reply(`в”ЊЛљв‚Љ а№‘в”‚ бґЂ Т“ ЙЄ Йґ ЙЄ бґ› бґЂ s  бґЌ Кџ в”‚а№‘Лљв‚Љ вљ пёЏ\nв”‡ \nв”‚ вќЊ *Format salah!*\nв”‚ \nв”‚ рџ“Њ *Cara pakai:*\nв”‚ Silakan reply/balas foto dengan perintah:\nв”‚ ${usedPrefix + command} <nomor_bg>\nв”‚ \nв”‚ рџ’Ў *Pilihan BG:* 1 s/d 6\nв”‚ рџ“Њ *Contoh:* ${usedPrefix + command} 2\nв”‡ \nв””Лљв‚Љ а№‘ в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ а№‘Лљв‚Љ\n> В© ERINE-AI`)
    }

    let bgIndex = text ? parseInt(text.trim()) : 1
    if (isNaN(bgIndex) || bgIndex < 1 || bgIndex > 6) {
        return m.reply(`в”ЊЛљв‚Љ а№‘в”‚ бґЂ Т“ ЙЄ Йґ ЙЄ бґ› бґЂ s  бґЌ Кџ в”‚а№‘Лљв‚Љ вљ пёЏ\nв”‡ \nв”‚ вќЊ *Nomor background tidak valid!*\nв”‚ Pilihan nomor background yang tersedia hanya 1 sampai 6.\nв”‡ \nв””Лљв‚Љ а№‘ в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ а№‘Лљв‚Љ\n> В© ERINE-AI`)
    }

    await m.react('вЏі')

    try {
        let media = await q.download()
        let formData = new FormData()
        let blob = new Blob([media], { type: mime })
        formData.append('file', blob, 'upload_file')

        let uploadRes = await fetch('https://api.shinzu.web.id/api/upload/litterbox', {
            method: 'POST',
            body: formData
        })
        let uploadJson = await uploadRes.json()
        if (!uploadJson.status || !uploadJson.result) throw new Error('Gagal mengunggah media ke cloud.')
        let imageUrl = uploadJson.result.url

        const apiUrl = `https://restapi.jagoanproject.web.id/api/maker/afinitasml?image=${encodeURIComponent(imageUrl)}&bg=${bgIndex}`
        
        const res = await fetch(apiUrl, {
            headers: {
                'Authorization': 'Bearer Lynxdecode'
            }
        })

        const contentType = res.headers.get('content-type') || ''
        let mediaPayload

        if (contentType.includes('application/json')) {
            const json = await res.json()
            if (!json.status) {
                throw new Error(json.message || JSON.stringify(json))
            }
            
            let resultUrl = json?.result?.url || json?.data?.result?.url
            
            if (!resultUrl) {
                throw new Error(`Respon JSON API tidak sesuai:\n${JSON.stringify(json, null, 2)}`)
            }
            mediaPayload = { url: resultUrl }
        } else if (contentType.includes('image') || contentType.includes('application/octet-stream')) {
            const buffer = Buffer.from(await res.arrayBuffer())
            mediaPayload = buffer
        } else {
            const errText = await res.text()
            throw new Error(`Tipe konten tidak valid (${contentType}):\n${errText.substring(0, 300)}`)
        }

        let caption = `в”ЊЛљв‚Љ а№‘в”‚ бґЂ Т“ ЙЄ Йґ ЙЄ бґ› бґЂ s  бґЌ Кџ в”‚а№‘Лљв‚Љ рџЋ®\n` +
                      `в”‡ \n` +
                      `в”‚ вњ… *Sukses membuat Afinitas MLBB!*\n` +
                      `в”‚ рџ–јпёЏ *Background Ke:* ${bgIndex}\n` +
                      `в”‡ \n` +
                      `в””Лљв‚Љ а№‘ в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ а№‘Лљв‚Љ\n` +
                      `> В© ERINE-AI`

        await conn.sendMessage(m.chat, {
            image: mediaPayload,
            caption: caption
        }, { quoted: m })

        await m.react('вњ…')

    } catch (error) {
        console.error('[AFINITASML ERROR]', error)
        await m.react('вќЊ')
        
        let errMsg = error.message || String(error)
        if (errMsg.length > 500) errMsg = errMsg.substring(0, 500) + '... (cek console)'

        m.reply(`в”ЊЛљв‚Љ а№‘в”‚ s КЏ s бґ› бґ‡ бґЌ  бґ‡ КЂ КЂ бґЏ КЂ в”‚а№‘Лљв‚Љ вќЊ\nв”‡ Terjadi kesalahan sistem.\nв”‡ *Detail:* ${errMsg}\nв””Лљв‚Љ а№‘ в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ а№‘Лљв‚Љ\n> В© ERINE-AI`)
    }
}

