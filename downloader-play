import yts from "yt-search"
import fetch from 'node-fetch'

let handler = async (m, { conn, text, usedPrefix, command }) => {
    const header = (title, emoji) => `в”ҢЛҡвӮҠ а№‘в”Ӯ ${title} в”Ӯа№‘ЛҡвӮҠ ${emoji}\nв”Ү \n`
    const footer = () => `\nв”Ү \nв””ЛҡвӮҠ а№‘ в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ а№‘ЛҡвӮҠ\n> В© ERINE-AI`

    if (!text) {
        return m.reply(header('YT PLAY MP3', 'рҹҺө') + `в”Ӯ вқҢ *Mau cari lagu apa di YouTube?*\nв”Ӯ *Contoh:* ${usedPrefix + command} Aftershock breakbeat` + footer())
    }

    await m.react('вҸі')

    try {
        let searchResults = await yts(text)
        let videos = searchResults.videos

        if (!videos || videos.length === 0) {
            throw new Error('Lagu tidak ditemukan di YouTube.')
        }

        let targetVideo = videos[0]
        let videoUrl = targetVideo.url

        let res = await fetch(`https://api.xrizal.my.id/api/downloader/ytmp3?url=${encodeURIComponent(videoUrl)}`, {
            headers: { 'Accept': 'application/json' }
        })
        let json = await res.json()

        if (!json.status || !json.result || !json.result.audio || json.result.audio.length === 0) {
            throw new Error('Gagal mengunduh audio dari server.')
        }

        let data = json.result
        let bestAudio = data.audio.find(a => a.quality === "131" || a.ext === "m4a") || data.audio[0]
        let downloadUrl = bestAudio.url
        let size = bestAudio.size || '-'

        let teks = header('PLAY YOUTUBE', 'рҹҺ§')
        teks += `в”Ӯ рҹҺө *Judul    :* ${data.title || targetVideo.title}\n`
        teks += `в”Ӯ вҸі *Durasi   :* ${data.duration || targetVideo.timestamp}\n`
        teks += `в”Ӯ рҹ“Ұ *Ukuran   :* ${size}\n`
        teks += `в”Ӯ рҹ‘Ө *Channel  :* ${targetVideo.author.name || '-'}\n`
        teks += `в”Ӯ рҹ”— *Link YT  :* ${videoUrl}\nв”Ӯ\n`
        teks += `в”Ӯ _Audio sedang dikirim, mohon ditunggu..._`
        teks += footer()

        await conn.sendMessage(m.chat, {
            image: { url: data.thumb || targetVideo.thumbnail },
            caption: teks
        }, { quoted: m })

        await conn.sendMessage(m.chat, {
            audio: { url: downloadUrl },
            mimetype: 'audio/mpeg',
            fileName: `${data.title || targetVideo.title}.mp3`
        }, { quoted: m })

        await m.react('вңЁ')

    } catch (e) {
        console.error(e)
        await m.react('вқҢ')
        m.reply(header('PLAY ERROR', 'вқҢ') + `в”Ӯ вқҢ *Terjadi kesalahan:*\nв”Ӯ ${e.message}` + footer())
    }
}

handler.help = ['play <pencarian>']
handler.tags = ['downloader']
handler.command = /^play$/i
handler.limit = true

export default handler