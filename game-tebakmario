import axios from 'axios'

let timeout = 60000
let poin = 500

let handler = async (m, { conn, usedPrefix, command }) => {
    conn.tebaksupermario = conn.tebaksupermario ? conn.tebaksupermario : {}
    let id = m.chat

    if (id in conn.tebaksupermario) {
        return m.reply('вқҢ Masih ada soal belum terjawab di grup ini.')
    }

    await m.react('вҸі')

    try {
        const { data } = await axios.get('https://restapi.jagoanproject.web.id/api/game/tebaksupermario', {
            headers: {
                'Authorization': 'Bearer Lynxdecode'
            }
        })

        if (!data.status || !data.result) throw new Error('Gagal mengambil data dari server.')

        let json = data.result
        let caption = `в”ҢЛҡвӮҠ а№‘в”Ӯ бҙӣ бҙҮ Кҷ бҙҖ бҙӢ  кңұ бҙң бҙҳ бҙҮ КҖ  бҙҚ бҙҖ КҖ ЙӘ бҙҸ в”Ӯа№‘ЛҡвӮҠ рҹҚ„\n` +
                      `в”Ү \n` +
                      `в”Ӯ вқ“ *Tebak Siapa Karakter Ini!*\n` +
                      `в”Ӯ вҸұпёҸ *Waktu:* ${(timeout / 1000).toFixed(0)} Detik\n` +
                      `в”Ӯ рҹҺҒ *Hadiah:* ${poin} XP\n` +
                      `в”Ү \n` +
                      `в”Ӯ рҹ’¬ *Balas pesan ini untuk menjawab*\n` +
                      `в””ЛҡвӮҠ а№‘ в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ а№‘ЛҡвӮҠ\n` +
                      `> В© ERINE-AI x INF PROJECT`

        conn.tebaksupermario[id] = [
            await conn.sendMessage(m.chat, { image: { url: json.img }, caption: caption }, { quoted: m }),
            json,
            poin,
            setTimeout(async () => {
                if (conn.tebaksupermario[id]) {
                    let msg = `в”ҢЛҡвӮҠ а№‘в”Ӯ бҙӣ бҙҮ Кҷ бҙҖ бҙӢ  кңұ бҙң бҙҳ бҙҮ КҖ  бҙҚ бҙҖ КҖ ЙӘ бҙҸ в”Ӯа№‘ЛҡвӮҠ рҹҚ„\n` +
                              `в”Ү \n` +
                              `в”Ӯ вқҢ *Waktu Habis!*\n` +
                              `в”Ӯ рҹ’Ў *Jawaban:* ${json.jawaban}\n` +
                              `в”Ү \n` +
                              `в””ЛҡвӮҠ а№‘ в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ а№‘ЛҡвӮҠ\n` +
                              `> В© ERINE-AI`
                    await conn.sendMessage(m.chat, { text: msg }, { quoted: conn.tebaksupermario[id][0] })
                    delete conn.tebaksupermario[id]
                }
            }, timeout)
        ]

        await m.react('вң…')
    } catch (e) {
        console.error('[TEBAK SUPER MARIO ERROR]', e)
        await m.react('вқҢ')
        m.reply(`в”ҢЛҡвӮҠ а№‘в”Ӯ кңұ КҸ кңұ бҙӣ бҙҮ бҙҚ  бҙҮ КҖ КҖ бҙҸ КҖ в”Ӯа№‘ЛҡвӮҠ вқҢ\nв”Ү Terjadi kesalahan.\nв”Ү *Detail:* ${e.message || String(e)}\nв””ЛҡвӮҠ а№‘ в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ а№‘ЛҡвӮҠ\n> В© ERINE-AI`)
    }
}

handler.before = async (m, { conn }) => {
    conn.tebaksupermario = conn.tebaksupermario ? conn.tebaksupermario : {}
    let id = m.chat
    
    if (!m.quoted || !m.quoted.fromMe || !m.quoted.isBaileys || !m.text) return false
    if (!(id in conn.tebaksupermario)) return false
    
    if (m.quoted.id === conn.tebaksupermario[id][0].key.id) {
        let json = JSON.parse(JSON.stringify(conn.tebaksupermario[id][1]))
        let answer = json.jawaban.toLowerCase().trim()
        
        if (m.text.toLowerCase().trim() === answer) {
            global.db.data.users[m.sender].exp += conn.tebaksupermario[id][2]
            
            let msg = `в”ҢЛҡвӮҠ а№‘в”Ӯ бҙӣ бҙҮ Кҷ бҙҖ бҙӢ  кңұ бҙң бҙҳ бҙҮ КҖ  бҙҚ бҙҖ КҖ ЙӘ бҙҸ в”Ӯа№‘ЛҡвӮҠ рҹҚ„\n` +
                      `в”Ү \n` +
                      `в”Ӯ рҹҺү *BENAR!*\n` +
                      `в”Ӯ рҹҺҒ *Hadiah:* +${conn.tebaksupermario[id][2]} XP\n` +
                      `в”Ү \n` +
                      `в””ЛҡвӮҠ а№‘ в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ а№‘ЛҡвӮҠ\n` +
                      `> В© ERINE-AI x INF PROJECT`
                      
            await conn.sendMessage(m.chat, { text: msg }, { quoted: m })
            
            clearTimeout(conn.tebaksupermario[id][3])
            delete conn.tebaksupermario[id]
            return true
        } else {
            await m.react('вқҢ')
            return false
        }
    }
    return false
}

handler.help = ['tebaksupermario']
handler.tags = ['game']
handler.command = /^(tebaksupermario)$/i
handler.limit = true

export default handler