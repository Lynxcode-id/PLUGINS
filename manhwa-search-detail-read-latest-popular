                txt += `│ ⭐️ *Rating:* ${v.rating}\n`
                txt += `│ 📖 *Chapter:* ${v.chapter}\n`
                txt += `│ 🔗 *Link:* ${v.url}\n`
                txt += `│ \n`
            })
            txt += `└˚₊ ๑ ────────────── ๑˚₊\n> © ERINE-AI`
            
            await m.reply(txt)
            await m.react('✅')

        } else if (action === 'detail') {
            if (!query) return m.reply(`❌ Masukkan URL manhwa cuy!\nContoh: ${usedPrefix + command} detail https://manhwalist02.asia/manga/...`)
            
            let res = await get_detail(query)
            let txt = `┌˚₊ ๑│ ᴍ ᴀ ɴ ʜ ᴡ ᴀ  ᴅ ᴇ ᴛ ᴀ ɪ ʟ │๑˚₊ 📖\n` +
                      `┇ \n` +
                      `│ 📌 *Judul:* ${res.title}\n` +
                      `│ ⭐️ *Rating:* ${res.rating}\n` +
                      `│ 🎭 *Genre:* ${res.genres.join(', ')}\n` +
                      `│ 📚 *Total Chapter:* ${res.total_chapters}\n` +
                      `┇ \n` +
