async function get_chapter_images(url) {
    const $ = await fetch_html(url)
    let images = []
    
    $('#readerarea img').each((_, el) => {
        let src = $(el).attr('src') || $(el).attr('data-src') || $(el).attr('data-lazy-src') || $(el).attr('data-cfsrc') || ''
        if (src.startsWith('data:image')) {
            src = $(el).attr('data-src') || $(el).attr('data-lazy-src') || $(el).attr('data-cfsrc') || ''
        }
        
        if (src && !src.includes('lazyload')) images.push(src.trim())
    })

    if (images.length === 0) {
        $('script').each((_, el) => {
            const scriptHtml = $(el).html() || ''
            if (scriptHtml.includes('ts_reader.run')) {
                try {
                    const match = scriptHtml.match(/ts_reader\.run\((.*?)\);/)
                    if (match && match[1]) {
                        const jsonData = JSON.parse(match[1])
                        if (jsonData.sources && jsonData.sources.length > 0) {
                            images = jsonData.sources[0].images
                        }
                    }
                } catch (e) {
                    console.log('Gagal parse ts_reader:', e.message)
                }
            }
        })
    }

    const title = $('h1.entry-title').text().trim() || 'Chapter'
    return { title, images: [...new Set(images)] }
}

async function buildPDF(images) {
    return new Promise(async (resolve, reject) => {
        try {
            const doc = new PDFDocument({ autoFirstPage: false })
            const buffers = []
            
            doc.on('data', chunk => buffers.push(chunk))
            doc.on('end', () => resolve(Buffer.concat(buffers)))
            doc.on('error', err => reject(err))

            for (let imgUrl of images) {
                try {
                    const response = await axios.get(imgUrl, {
                        responseType: 'arraybuffer',
                        headers: {
                            'Referer': base_url,
                            'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/109.0.0.0 Safari/537.36'
                        }
                    })
                    const imgBuffer = Buffer.from(response.data)
                    const img = doc.openImage(imgBuffer)
                    doc.addPage({ size: [img.width, img.height], margin: 0 })
                    doc.image(imgBuffer, 0, 0, { width: img.width, height: img.height })
                } catch (imgErr) {
                    console.error('Failed to load image for PDF:', imgUrl)
                }
            }
            doc.end()
        } catch (e) {
            reject(e)
        }
    })
}

