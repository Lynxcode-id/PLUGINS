            })
            txt += `└˚₊ ๑ ────────────── ๑˚₊\n> © ERINE-AI`
            
            await m.reply(txt)
            await m.react('✅')

        } else if (action === 'latest' || action === 'popular') {
            let res = action === 'latest' ? await get_latest() : await get_popular()
            
