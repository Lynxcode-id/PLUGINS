                      `┇ \n` +
                      `└˚₊ ๑ ────────────── ๑˚₊\n` +
                      `> © ERINE-AI`

            await conn.sendMessage(m.chat, { image: { url: res.cover }, caption: txt }, { quoted: m })
            await m.react('✅')

        } else if (action === 'read' || action === 'download') {
            if (!query) return m.reply(`❌ Masukkan URL chapter cuy!\nContoh: ${usedPrefix + command} read https://manhwalist02.asia/...-chapter-1/`)
            
            m.reply('⏳ *Processing PDF...*\nMohon tunggu cuy, bot sedang mendownload gambar dan menjadikannya PDF (Mungkin butuh waktu agak lama karena total halaman).')
            
            let chapterData = await get_chapter_images(query)
            if (!chapterData.images || !chapterData.images.length) throw new Error('Tidak ada gambar chapter yang ditemukan di link tersebut (Tembok lazy-load / error parsing script).')

            let pdfBuffer = await buildPDF(chapterData.images)

            let txt = `┌˚₊ ๑│ ᴍ ᴀ ɴ ʜ ᴡ ᴀ  ʀ ᴇ ᴀ ᴅ ᴇ ʀ │๑˚₊ 📥\n` +
